.pytest_cache/
.coverage
htmlcov/
.tox/

# ── RP Utility — personal game data ──────────────────────────────────────────
# The SQLite database holds all sessions, conversation history,
# memories, relationships, and every other piece of game state.
# None of this should ever be committed.
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# ── Character cards — ignore everything except the demo card ─────────────────
data/cards/*
!data/cards/lyra_ashveil.json

# ── Lorebooks — ignore everything except the demo lorebook ───────────────────
data/lorebooks/*
!data/lorebooks/crosshaven_and_the_ashfen.json
