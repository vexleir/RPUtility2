# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.installed.cfg
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Local configuration (contains secrets / personal settings) ────────────────
.env
.env.*

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

